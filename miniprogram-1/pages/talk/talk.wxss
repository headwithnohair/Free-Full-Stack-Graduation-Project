/* pages/talk/talk.wxss */
page {
  background-color: #f1f1f1;
}
.grid-container {
  display: grid;

  grid-template-columns: 80rpx max-content;
  grid-template-rows: 40rpx 40rpx;
}
.grid-container2 {

  display: grid;
  grid-template-columns: 500rpx 500rpx ;
  grid-template-rows: 60rpx auto;
}
.no_picture{
  margin-top: 5px;
  grid-column: 1 / span 3;
  white-space: normal;  overflow: hidden;text-overflow:ellipsis;-webkit-line-clamp: 5;display: -webkit-box;-webkit-box-orient: vertical;height:max-content;
   word-break: break-all; text-indent: 2em;
   word-wrap: break-word;
}
.yes_picture{

  display: inline-block;white-space: normal;  overflow: hidden;text-overflow:ellipsis;-webkit-line-clamp: 5;display: -webkit-box;-webkit-box-orient: vertical;height:max-content;   word-break: break-all;word-wrap: break-word; text-indent: 2em;

}
.content{
  background-color: white;
  border-radius: 10rpx;
}
.movable-area{
  pointer-events:none;
 
  width: 100%;
  height: 100%;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}
.movable-view{ 
  pointer-events:auto;
  height: 150rpx;
  width: 150rpx;
 border-radius: 50%;
  background: #8ca1fa;
  display:flex;
  align-items: center;
  justify-content: center;
 
}
.plus {
  
  font-size: 80px;
  color: white;
}