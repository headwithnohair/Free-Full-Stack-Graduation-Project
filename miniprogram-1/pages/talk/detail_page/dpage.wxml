<!--pages/talk/detail_page/dpage.wxml-->
<view wx:if="{{time}}">
  你的网络有问题，无法加载事件，请返回首页！
</view>
<view wx:else>
 
<view style="margin-top: 20rpx;width: fit-content;" class="content" >

  <view style="width: 100%;border-radius: 10rpx;margin-left: 8px;" class="grid-c">
    <image src="{{'http://localhost:1234/user/gaveIcon?userId='+detail.userId}}" style=" width:80rpx;height:80rpx;grid-row: 1 / 3;;border-radius: 100%;margin-top: 5px;"/>
    <view style="height: 100%;width: 650rpx;">
      <text style="margin-left: 10px;font-weight: 800;font-size: 18px;margin-top: 5px;">{{detail.userName}}</text>
    </view>
    <text style="margin-left: 10px;color: rgb(94, 94, 94) ;margin-top: 5px;">   {{detail.actiontime}}  *  发布了文章  </text>
  </view>


  <view style="margin-top:10px;border-radius: 10rpx;height:min-content;margin-left: 5px;" >
    <p style="grid-column: 1 / span 3;font-weight:bolder;font-size: 25px;">{{detail.post.title}}</p>
    <text style="display: inline-block;height:max-content;word-break:break-all;line-height: 1.5;text-indent: 2em;font-size: 15px;">{{detail.post.content}}
</text>




<view style=" width: 100%;" wx:if="{{ninePicMode}}">
<view  style="text-align: center;" wx:if="{{detail.post.picture.pic.length<2}}">
  <image src="{{detail.post.picture.pic[0]}}" style="margin-left: 5px;" mode="heightFix" catch:tap="pictureDetail" data-url="{{detail.post.picture.pic[0]}}" data-entity="{{detail.post.picture}}"></image>
</view>
<view wx:else="">
  <view wx:for="{{detail.post.picture.pic}}" wx:key="idx" wx:for-item="pic" style="display: inline-block;">
  <image src="{{pic}}" style="margin-left: 5px;width: 115px;height: 115px; " mode="aspectFit" catch:tap="pictureDetail" data-url="{{pic}}" data-entity="{{detail.post.picture}}"></image>
  </view>
  </view>
</view>
</view>

<view>
  <view  style="height: 20px;margin-top: 20px;width: 100%;display: inline-block;border-bottom: 1px solid rgb(122, 122, 122);padding-bottom: 5px;">
  <text style="font-weight: 700;margin-left: 10px;">回复</text>
  </view>

<view>
  <view>
    <view wx:for="{{reply}}" wx:for-item="reply" wx:key="wtf">
      <view style="width: 100%;border-radius: 10rpx;margin-left: 8px;margin-top: 5px;" class="grid-c">

<image src="{{'http://localhost:1234/user/gaveIcon?userId='+reply.userId}}" style=" width:80rpx;height:80rpx;grid-row: 1 / 3;;border-radius: 100%;margin-top: 5px;"/>
<view style="height: 100%;width: 650rpx;">
  <text style="margin-left: 10px;font-weight: 800;font-size: 18px;margin-top: 5px;">{{reply.userName}}</text>
</view>
<text style="margin-left: 10px;color: rgb(94, 94, 94) ;margin-top: 5px;">   {{reply.actiontime}}  *  回复了  </text>
<view style="margin-top: 5px;width: 350px;height:max-content;">

<text style="word-break:break-all;line-height: 1.5;font-size: 15px;"> {{reply.reply.reply}}</text>
</view>
</view>
 </view>

</view>
</view>


</view>


</view>
</view>
<view style="text-align: center;color: #7e7d7d;" wx:if="{{!getreply}}">
    <text>没有更多了</text>
</view>
<view style="height: 50px;">

</view>
<!--悬浮回复框-->
<view style="position:absolute;bottom:{{-testt}}px;z-index: 5;height: 40px;width: 100%;background-color: rgb(255, 255, 255);padding-top: 5px;align-items: center;">
  
<view style="border-radius: 10px;border:1px solid rgb(94, 94, 94);padding-left: 5px;margin-left: 5px;margin-right: 5px;display: inline-block;width: 65%;height: 30px;">
  <input type="text" style="height: 30px;" placeholder="来回复我ya" id="post"> </input>
</view>

<view style="border-radius: 100%;display: inline-block;height: 35px;width: 35px;background-color: rgb(250, 214, 214);">
</view>
<view style="border-radius: 100%;display: inline-block;height: 35px;width: 35px;background-color: rgb(107, 235, 207);">
</view>
<view style="border-radius: 100%;display: inline-block;height: 35px;width: 35px;background-color: rgb(238, 101, 101);" bind:tap="replyPost" > 
</view>

</view>


