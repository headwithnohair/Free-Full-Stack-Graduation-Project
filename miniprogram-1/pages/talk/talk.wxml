<!--pages/talk/talk.wxml-->


<view style="text-align: center;margin-top: 40px;" wx:if="{{!tt}}">
  <text style="width: max-content;">下拉获得更多精彩动态！</text>
</view>
<view wx:else style="text-align: center;margin-top: 50px;"></view>

<grid-view type="align" wx:for="{{postList}}" wx:for-item="user" wx:key="idx" >
  <view style="margin-top: 20rpx;width: fit-content;" class="content" bind:tap="test" data-url="{{user}}">
   
  <view style="width: 100%;border-radius: 10rpx;margin-left: 8px;margin-top: 5px;" class="grid-container">
    <image src="{{'http://localhost:1234/user/gaveIcon?userId='+user.userId}}" style=" width:80rpx;height:80rpx;grid-row: 1 / 3;;border-radius: 100%;"/>
    <view style="height: 100%;width: 650rpx;">
      <text style="margin-left: 10px;font-weight: 800;font-size: 18px;">{{user.userName}}</text>
    </view>
    <text style="margin-left: 10px;color: rgb(94, 94, 94) ;">   {{user.actiontime}}  *  发布了文章  </text>
  </view>


  <view style="margin-left: 8px;height:max-content;border-radius: 10rpx;margin-top: 10px;padding-bottom: 15px;" class="{{user.post.picture?'grid-container2':''}}">
    <p style="grid-column: 1 / span 3;font-weight:bolder;font-size: 40rpx;">{{user.post.title}}</p>
    <text   class="{{user.post.picture?'yes_picture':'no_picture'}}"
   >{{user.post.content}}</text>
<view wx:if="{{user.post.picture}}">

<view style=" width: 40%; height: auto;object-fit: contain;">

<image src="{{'http://localhost:1234/post/givePic?src='+user.post.picture.pic[0]}}" style="grid-column: 2 / span 3;display: inline-block;width: 200rpx;object-fit:cover; height: 200rpx; margin-left: 10px;overflow: hidden; border-radius: 5px;" />
</view>
</view>
</view>
</view>

</grid-view>

<movable-area class="movable-area">
    <movable-view class="movable-view" direction="all" x="600rpx" y="800rpx" bind:tap="jump_link" data-url="/pages/funtions/postPage/post_page">
      <view>
      <text class="plus">+</text>
    </view>
      
    </movable-view>
    
</movable-area>