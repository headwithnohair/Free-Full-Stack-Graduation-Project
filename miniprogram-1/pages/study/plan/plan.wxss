/* pages/study/plan/plan.wxss */
page {
  background-color: #ffcdcc;
}

.grid-container {

  display: grid;
  grid-template-columns:  150rpx 450rpx 150rpx ;
  text-align: center;
  grid-template-rows: 50rpx 50rpx 50rpx 50rpx;
}
.test1{
  filter: drop-shadow(5px 5px 5px  rgba(0, 0, 0, 0.3)) 
          drop-shadow(10px 10px 5px rgba(190, 190, 190, 0.2)) 
          drop-shadow(15px 15px 5px rgba(172, 236, 255,0.1));
          
  border-radius: 10px;
}
.test{
  filter: drop-shadow(3px 3px 3px  rgba(204, 204, 255, 0.5)) 
          drop-shadow(6px 6px 3px rgba(204, 204, 255, 0.3)) 
          drop-shadow(9px 9px 3px rgba(204, 204, 255, 0.1));
}
/*弹窗蒙层*/
.popup-box{
  position: absolute;
  z-index: 99;
  top: 0;
  background-color: rgba(0, 0, 0, 0.5);
  width: 100%;
  height: 100%;
}
.info-bottom{
  position: fixed;
  z-index: 999;
  margin-left: 80rpx;
  width: 80%;
  bottom: 500rpx;
  background-color: white;
  border-top-left-radius: 10rpx;
  border-top-right-radius: 10rpx;
}